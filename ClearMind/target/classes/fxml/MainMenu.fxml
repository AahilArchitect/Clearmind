<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.clearmind.MainMenuController">

   <children>
      <AnchorPane prefHeight="284.0" prefWidth="484.0">

         <children>

            <Button fx:id="startButton"
                    layoutX="409.0"
                    layoutY="238.0"
                    text="Start"
                    onAction="#openNotes">
               <font>
                  <Font name="Thonburi" size="14.0" />
               </font>
            </Button>

            <ImageView fitHeight="200.0"
                       fitWidth="200.0"
                       layoutX="14.0"
                       layoutY="-13.0">
               <image>
                  <Image url="@../images/Start_Logo_Improved.png" />
               </image>
            </ImageView>

         </children>

      </AnchorPane>
   </children>

</StackPane>
